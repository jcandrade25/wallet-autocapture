# ── wallet-autocapture: keep ALL personal data and secrets out of this PUBLIC repo ──

# Your real configuration (UUIDs, account numbers, names, email, payees).
# Only config.example.json (placeholders) is committed.
config.json

# Wallet API token (Bearer). Generated at web.budgetbakers.com -> Settings -> API.
.wallet_token

# IMAP / email app passwords. Any file matching these names, anywhere.
*_imap
.wallet_imap
.env
.env.*

# Run logs (may contain merchant names, amounts, account hints).
logs/

# Caches / derived data that can leak transactions or merchant history.
embed_index.json
merchant_memory.json
historial.json
snippets*.json
propuesta.json

# Reconciliation / statement data exports.
*.csv
# ...but DO ship the fictional sample fixture used by test_adapter.py:
!sample/expected.csv

# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/

# Virtual environments
.venv/
venv/
env/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# ── sample/ exception: ship SANITIZED, fictional example emails for testing the
#    bank adapters, but never let a real exported email or snippet slip in. ──
sample/*.eml
sample/real*
!sample/example_*.txt

# Runtime incident flag (generated by run_daily)
CAPTURE_ERROR.txt
capturas_log.md
